{
    "model_type": "autoencoder",
    "sample_size": 196608,
    "sample_rate": 44100,
    "audio_channels": 1,
    "model": {
        "encoder": {
            "type": "oobleck",
            "config": {
                "in_channels": 1,
                "channels": 128,
                "c_mults": [1, 2, 4, 8, 16],
                "strides": [2, 4, 4, 8, 8],
                "latent_dim": 64,
                "use_snake": true
            }
        },
        "decoder": {
            "type": "oobleck",
            "config": {
                "out_channels": 1,
                "channels": 128,
                "c_mults": [1, 2, 4, 8, 16],
                "strides": [2, 4, 4, 8, 8],
                "latent_dim": 64,
                "use_snake": true,
                "final_tanh": false
            }
        },
        "bottleneck": {
            "type": "rvq",
            "config": {
                "num_quantizers": 4,
                "codebook_size": 2048,
                "dim": 64,
                "decay": 0.99,
                "threshold_ema_dead_code": 2
            }
        },
        "latent_dim": 64,
        "downsampling_ratio": 2048,
        "io_channels": 1
    },
    "training": {
        "learning_rate": 1.5e-4,
        "warmup_steps": 0,
        "use_ema": true,
        "optimizer_configs": {
            "autoencoder": {
                "optimizer": {
                    "type": "AdamW",
                    "config": {
                        "betas": [0.8, 0.99],
                        "lr": 1.5e-5,
                        "weight_decay": 1e-3
                    }
                },
                "scheduler": {
                    "type": "InverseLR",
                    "config": {
                        "inv_gamma": 200000,
                        "power": 0.5,
                        "warmup": 0.999
                    }
                }
            }

        },
        "loss_configs": {
            "spectral": {
                "type": "mrstft",
                "config": {
                    "fft_sizes": [2048, 1024, 512, 256, 128, 64, 32],
                    "hop_sizes": [512, 256, 128, 64, 32, 16, 8],
                    "win_lengths": [2048, 1024, 512, 256, 128, 64, 32],
                    "perceptual_weighting": true
                },
                "weights": {
                    "mrstft": 1.0
                }
            },
            "time": {
                "type": "l1",
                "weights": {
                    "l1": 0.0
                }
            },
            "bottleneck": {
                "type": "rvq",
                "weights": {
                    "kl": 1e-4
                }
            }
        },
        "demo": {
            "demo_every": 2000
        }
    }
}
